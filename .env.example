# Heimdall AI Automation — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
#
# Security model:
#   • HEIMDALL_VAULT_KEY is the ONLY secret stored here — it is the master key
#     used to decrypt the vault (data/vault.json.enc).
#   • ALL other secrets (API keys, bot tokens, passwords) are stored ENCRYPTED
#     in data/vault.json.enc.  Add them via the Settings page or the /vault API.
#   • Generate a vault key:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ── Vault master key (REQUIRED) ───────────────────────────────────────────────
HEIMDALL_VAULT_KEY=<generate-with-fernet>

# ── Server ────────────────────────────────────────────────────────────────────
HEIMDALL_HOST=0.0.0.0
HEIMDALL_PORT=8000
# JWT secret for the API — generate a long random string
HEIMDALL_SECRET_KEY=change-me-use-a-long-random-string

# ── Local model endpoints (not secret — just network config) ──────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
LMSTUDIO_BASE_URL=http://127.0.0.1:1234

# ── Optional path overrides ───────────────────────────────────────────────────
HEIMDALL_DATA_DIR=data
HEIMDALL_CONFIG_DIR=config
HEIMDALL_TASKS_DIR=tasks
HEIMDALL_WORKSPACE_DIR=workspace

# ─────────────────────────────────────────────────────────────────────────────
# Secrets that go into the VAULT (not here) — add via Settings UI or /vault API:
#
#   anthropic_key       Claude API key (sk-ant-...)
#   openai_key          OpenAI API key (sk-...)
#   dashscope_key       Qwen DashScope key (if using cloud Qwen instead of Ollama)
#   grok_key            xAI Grok key (xai-...)
#   gemini_key          Google Gemini key
#   github_token        GitHub PAT (ghp_...)
#   telegram_bot_token  Telegram bot token
#   discord_bot_token   Discord bot token
#   email_smtp_password SMTP app password
#   email_imap_password IMAP app password
# ─────────────────────────────────────────────────────────────────────────────
